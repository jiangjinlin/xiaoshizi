# ================== Django 考试系统 环境变量示例 (.env.example) ==================
# 复制为 .env 或在部署平台(如 Docker / CI / 服务器)中设置等价变量。
# 未设置时项目会使用合理的默认值（开发友好），生产必须显式配置的项请务必修改！
# ----------------------------------------------------------------------------
# 基础框架
DJANGO_SECRET_KEY=请替换为生产随机密钥
DJANGO_DEBUG=0                   # 生产=0, 开发=1
DJANGO_ALLOWED_HOSTS=example.com,www.example.com   # 生产必须配置；多个主机用逗号分隔

# 可选：启用 Django CSRF 中间件（前端需带 X-CSRFToken）
DJANGO_ENABLE_CSRF=0             # 生产建议=1

# CORS（生产建议精确列出允许的前端域名，仅当 DJANGO_DEBUG=0 且未设置 CORS_ALLOW_ALL_ORIGINS 时生效）
CORS_ALLOWED_ORIGINS=https://exam-frontend.example.com

# 注册开关（0 关闭公开注册；管理员可手动建号）
ALLOW_PUBLIC_REGISTRATION=0

# Session / Cookie
SESSION_COOKIE_AGE=28800         # 会话有效期（秒），默认 8 小时
SESSION_COOKIE_SECURE=1          # 生产建议 1（HTTPS）
CSRF_COOKIE_SECURE=1             # 同上

# 代理/HTTPS 相关（按需）
USE_X_FORWARDED_HOST=1           # 反向代理后获取原 Host
SECURE_PROXY_SSL_HEADER=1        # 信任 X-Forwarded-Proto: https
SECURE_SSL_REDIRECT=1            # 自动 301 跳转到 HTTPS（部署前确保证书 OK）
SECURE_HSTS_SECONDS=31536000     # HSTS（一年），若首次部署不确定可暂用 0

# 数据库配置（默认使用 MySQL；测试模式自动切换 sqlite3）
DB_ENGINE=django.db.backends.mysql
DB_NAME=exam_system
DB_USER=exam_user
DB_PASSWORD=StrongPasswordHere
DB_HOST=127.0.0.1
DB_PORT=3306

# （可选）切换为 sqlite（单文件）时，可直接注释上面并设：
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=/data/exam.sqlite3

# ================== Baidu 人脸识别（若启用云端识别，需配置） ==================
BAIDU_FACE_APP_ID=your_app_id
BAIDU_FACE_API_KEY=your_api_key
BAIDU_FACE_SECRET_KEY=your_secret_key
BAIDU_FACE_GROUP_ID=exam_users
BAIDU_FACE_THRESHOLD=80.0        # 云端相似度阈值

# 本地人脸识别阈值（平均哈希 aHash 相似度 0-100）
LOCAL_FACE_THRESHOLD=85.0
FACE_SIGNIN_TTL_MINUTES=120      # 人脸签到后有效考试时间窗口（分钟）

# ================== DRF 接口限流（按需调整） ==================
DRF_THROTTLE_RATE_ANON=200/min
DRF_THROTTLE_RATE_USER=600/min
DRF_THROTTLE_RATE_LOGIN=20/min
DRF_THROTTLE_RATE_REGISTER=10/min
DRF_THROTTLE_RATE_FACE=30/min
DRF_THROTTLE_RATE_IMPORT=10/min

# ================== 登录防暴力破解（应用层） ==================
LOGIN_MAX_ATTEMPTS=5             # 阈值
LOGIN_WINDOW_SECONDS=600         # 统计窗口（秒）
LOGIN_LOCK_SECONDS=600           # 触发后锁定时长（秒）

# ================== 上传与请求大小限制 ==================
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760    # 10MB 全局请求体内存阈值
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880     # 5MB 单内存文件临界
AVATAR_MAX_BYTES=2097152                # 2MB 头像
FACE_IMAGE_MAX_BYTES=3145728            # 3MB 人脸图片
EXCEL_MAX_BYTES=8388608                 # 8MB 题库导入

# ================== 其他安全相关（按需） ==================
# 强制内容安全策略（未内置，若将来加 CSP 中间件可在此配置）
# CSP_DEFAULT_SRC='\'self\''

# ================== 日志（可在运行脚本引用这些变量决定日志级别） ==================
# LOG_LEVEL=INFO

# =============================================================================
# 使用说明：
# 1. 复制本文件为 .env 并根据环境修改敏感参数。
# 2. Docker 部署可在 docker-compose.yml 中使用 env_file 指定。
# 3. 不要把实际生产 .env 文件提交到版本库。
# 4. 如需添加新变量，保持注释清晰并更新本模板。
# =============================================================================

